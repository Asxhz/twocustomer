# Web (Next.js) environment — copy to web/.env.local and fill in.
# Next only reads env from this web/ directory, NOT the repo-root .env.

# Agent control plane the web app proxies to.
AGENT_BASE_URL=http://localhost:8000
# Must match the agent's AGENT_SHARED_TOKEN (server-only; never NEXT_PUBLIC_*).
AGENT_SHARED_TOKEN=

# Convex deployment URL — required for the dashboard to show LIVE data
# (mentions / insights / campaigns). Without it the UI falls back to mock.
CONVEX_URL=

# Optional: Discord bot client id enables the onboarding "Add to Discord" OAuth
# connector. Public by design.
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# Sessions: signed cookie + Redis revocation. SESSION_SECRET signs the cookie
# (use a long random string in prod). UPSTASH_* are the SAME creds as the agent
# and back server-side session revocation. Falls back to AGENT_SHARED_TOKEN if
# SESSION_SECRET is unset (fine for local dev).
SESSION_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GitHub OAuth App (Connect GitHub → FDE reads repo + opens PRs). Register an
# OAuth App with callback <WEB_BASE_URL>/api/github/oauth/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# The deployed web origin, used to build the OAuth callback URL.
WEB_BASE_URL=http://localhost:3000

# DEMO_MODE=1 shows sample data when Convex is unreachable (local only). Leave
# unset in production so the UI never fabricates data.
DEMO_MODE=

# Auth: email sign-in mints a signed, role-bearing session (admin | customer).
# /admin/* is admin-only and /u/* requires sign-in (enforced in proxy.ts).
