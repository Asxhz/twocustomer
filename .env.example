# ── TwoCustomer environment ──────────────────────────────────────────────
# Copy to .env and fill in. scripts/check_env.py reports what's set.

# ── Anthropic (Claude brain) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Browserbase (web monitoring) ─────────────────────────────────────────
BROWSERBASE_API_KEY=        # bb_live_... (the API key)
BROWSERBASE_PROJECT_ID=     # the project UUID (not the bb_live key!)

# ── Deepgram (voice STT/TTS) ─────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── Gemini (AI image generation + editing) ───────────────────────────────
GEMINI_API_KEY=             # aistudio.google.com/apikey
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Daily (video + screen-share sessions) ────────────────────────────────
DAILY_API_KEY=              # dashboard.daily.co -> Developers
DAILY_DOMAIN=               # your-team.daily.co

# ── Twilio (SMS + phone-call interviews) ─────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=         # +15551234567

# ── Vercel (FDE sandbox preview deploys) ─────────────────────────────────
VERCEL_TOKEN=

# ── Fetch AI / ASI:One / Agentverse (uAgent discovery) ───────────────────
ASI_ONE_API_KEY=
AGENTVERSE_API_KEY=
UAGENT_SEED=                # stable seed phrase -> stable agent address

# ── Upstash Redis (memory + cache) ───────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Convex (realtime state) ──────────────────────────────────────────────
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ── Discord (free Slack alternative) ─────────────────────────────────────
DISCORD_PUBLIC_KEY=         # App -> General Information -> Public Key
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=        # Channel -> Integrations -> Webhooks

# ── Slack (optional brand channel) ───────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALERT_CHANNEL=

# ── Auth between services ────────────────────────────────────────────────
AGENT_SHARED_TOKEN=         # bearer token enforced on the agent; web + uagent send it

# ── Service wiring ───────────────────────────────────────────────────────
AGENT_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# ── Optional / stretch ───────────────────────────────────────────────────
SENTRY_DSN=
ARIZE_API_KEY=
ARIZE_SPACE_ID=
